DOSSIER_PYTHON=/opt/conda/bin/python
DOSSIER_VLLM_PYTHON=/opt/conda/bin/python

# OpenAI-compatible server, e.g. vLLM
OPENAI_API_KEY=EMPTY
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_MODEL=/workspace/DOSSIER/models/Llama-3.1-8B-Instruct
OPENAI_DEFAULT_TEMPERATURE=0
OPENAI_TIMEOUT_SECONDS=3600
OPENAI_THINKING_MODULES=

# Module output-token caps. Each call's input + output must fit
# DOSSIER_VLLM_MAX_MODEL_LEN. Caps are sized to the actual output
# shapes (TOC entries, 5W1H records, etc.) — bumping them too high
# encourages weak models to ramble and dramatically slows the run.
DOSSIER_TOC_BUILDER_MAX_OUTPUT_TOKENS=16384
DOSSIER_SEARCH_AGENT_MAX_OUTPUT_TOKENS=8192
DOSSIER_COMPOSER_MAX_OUTPUT_TOKENS=16384
DOSSIER_FORMATTER_MAX_OUTPUT_TOKENS=8192
DOSSIER_LLM_JUDGE_MAX_OUTPUT_TOKENS=400

# vLLM launcher defaults
DOSSIER_VLLM_HOST=127.0.0.1
DOSSIER_VLLM_PORT=8000
DOSSIER_VLLM_MODEL_PATH=/workspace/DOSSIER/models/Llama-3.1-8B-Instruct
DOSSIER_VLLM_TP_SIZE=4
DOSSIER_VLLM_MAX_MODEL_LEN=260000
DOSSIER_VLLM_GPU_MEMORY_UTILIZATION=0.93
DOSSIER_VLLM_MAX_NUM_SEQS=1
# Pass extra vLLM CLI args (e.g. rope-scaling for >128K with Llama-3.1)
DOSSIER_VLLM_EXTRA_ARGS=--hf-overrides {"rope_scaling":{"rope_type":"linear","factor":2.0}}
# Llama-3.1 doesn't expose a reasoning-parser; leave empty for Llama,
# set to qwen3 when serving Qwen3.5 models.
DOSSIER_VLLM_REASONING_PARSER=
# vLLM rejects max-model-len > model's native max_position_embeddings
# unless this safety bypass is set (Llama-3.1 native = 128K, we want 260K).
DOSSIER_VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
